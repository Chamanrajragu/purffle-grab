{
  "name": "purfflegrab",
  "version": "2.0.0",
  "description": "PurffleGrab — a clean, free Spotify & YouTube downloader",
  "author": "Purffle",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "server": "node server/standalone.js",
    "dist": "electron-builder --win nsis",
    "pack": "electron-builder --dir"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.purffle.purfflegrab",
    "productName": "PurffleGrab",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "server/**/*",
      "public/**/*",
      "package.json"
    ],
    "extraResources": [
      { "from": "bin", "to": "bin" }
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PurffleGrab",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    }
  }
}
